#include <iostream>

using namespace std;

class Student {
private:
    int studentId;
    string name;
    float grade;

public:
    Student() {
        studentId = 0;
        name = "Unknown";
        grade = 0.0;
    }

    void inputDetails() {
        cout << "Enter Student ID: ";
        cin >> studentId;
        cout << "Enter Name: ";
        cin >> name; 
        cout << "Enter Grade: ";
        cin >> grade;
    }

    void displayDetails() const {
        cout << "Student ID: " << studentId << ", Name: " << name << ", Grade: " << grade << endl;
    }
};

int main()
{
    const int SIZE = 3; 
    Student students[SIZE]; 
    
    for (int i = 0; i < SIZE; i++) {
        students[i].inputDetails();
    }

    cout << "\nStudent Details:\n";

    for (int i = 0; i < SIZE; i++) {
        students[i].displayDetails();
    }

    return 0;
}
